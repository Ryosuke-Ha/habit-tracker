# Google OAuth
# Google Cloud Console (https://console.cloud.google.com/) でOAuth 2.0クライアントIDを作成
GOOGLE_CLIENT_ID=          # Google Cloud ConsoleのクライアントID
GOOGLE_CLIENT_SECRET=      # Google Cloud Consoleのクライアントシークレット

# NextAuth
# openssl rand -base64 32 で生成
NEXTAUTH_SECRET=           # openssl rand -base64 32 で生成
NEXTAUTH_URL=              # 本番環境のURL（例: https://your-app.vercel.app）、開発時は http://localhost:3000

# Backend
NEXT_PUBLIC_BACKEND_URL=   # FastAPIのURL（例: http://localhost:8000）
